# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DATABASE_URL and DB_NAME unset to use SQLite locally (backend/db.sqlite3).
# Render injects DATABASE_URL automatically when linked to managed Postgres.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_NAME=tournament_db
# DB_USER=tournament_user
# DB_PASSWORD=your-database-password
# DB_HOST=localhost
# DB_PORT=5432

# Frontend URL (for CORS / CSRF in production)
FRONTEND_URL=http://localhost:5173
# CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# Email Configuration (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yoursite.com

# Security (production only — applied when DEBUG=False)
SECURE_SSL_REDIRECT=False
